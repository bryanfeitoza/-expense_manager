# Gerenciador de Gastos com IA - Variáveis de Ambiente

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=gerenciador_gastos
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_ACCESS_SECRET=seu-access-secret-aqui-mude-em-producao
JWT_REFRESH_SECRET=seu-refresh-secret-aqui-mude-em-producao
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# IA
AI_API_KEY=sua-api-key-da-ia-aqui
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4

# Server
NODE_PORT=3000
PYTHON_PORT=8000
JAVA_PORT=8080
NGINX_PORT=80

# Node
NODE_ENV=development

# Python
PYTHON_ENV=development

# Java
JAVA_ENV=development
